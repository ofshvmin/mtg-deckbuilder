# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# MongoDB Atlas connection string (mongodb+srv://user:pass@cluster.../)
MONGODB_URI=
MONGODB_DB=mtg_deckbuilder

# Auth — generate a strong random secret, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14

# SMTP for password-reset emails. Leave SMTP_HOST empty to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Grimoire <noreply@example.com>

# Frontend URL (for building reset links in emails)
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed browser origins for CORS
CORS_ORIGINS=http://localhost:5173
# Optional regex for CORS (e.g. allow all Vercel deploys incl. previews):
#   CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGIN_REGEX=
