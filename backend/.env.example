# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# MongoDB Atlas connection string (mongodb+srv://user:pass@cluster.../)
MONGODB_URI=
MONGODB_DB=mtg_deckbuilder

# Auth — generate a strong random secret, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14

# Comma-separated list of allowed browser origins for CORS
CORS_ORIGINS=http://localhost:5173
